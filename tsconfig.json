{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		// Every file the type-checker sees is TypeScript — no allowJs. The only
		// remaining .js (svelte.config.js, server.js) are loaded outside Vite /
		// run directly at runtime and aren't part of this program.
		"allowJs": false,
		"strict": true,
		// don't type-check third-party .d.ts files (e.g. type-fest internals,
		// @svelte-plugins/datepicker) — our own sources stay fully strict.
		"skipLibCheck": true
	}
}
